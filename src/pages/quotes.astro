---
import MainLayout from '../layouts/MainLayout.astro';
import { getPageByPermalink } from '../lib/content';
const page = getPageByPermalink('/quotes');
---
<MainLayout title={page?.title} description={page?.description}>
  <section class="page-hero bs-starfield" aria-label="Page intro">
    <div class="page-hero__inner">
      <div class="bs-label page-hero__kicker">
        <svg class="bs-twinkle" viewBox="0 0 100 100" width="18" height="18" aria-hidden="true">
          <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gold-400)" />
        </svg>
        Collected fragments
      </div>
      <h1>{page?.title}</h1>
      <p class="page-hero__desc">A small reference shelf of lines worth keeping around.</p>
    </div>
  </section>
  {page && <section class="section article-shell"><div class="article-body" set:html={page.html}></div></section>}
</MainLayout>
