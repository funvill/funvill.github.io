---
import MainLayout from '../../../layouts/MainLayout.astro';
import Pagination from '../../../components/Pagination.astro';
import PostListItem from '../../../components/PostListItem.astro';
import { getPosts, paginate } from '../../../lib/content';

export function getStaticPaths() {
  const totalPages = Math.ceil(getPosts().length / 10);
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => ({
    params: { page: String(index + 2) }
  }));
}

const currentPage = Number(Astro.params.page ?? '2');
const pager = paginate(getPosts(), currentPage, 10);

const WPM = 220;
const readMinutes = (raw?: string) => Math.max(1, Math.round((raw ?? '').split(/\s+/).filter(Boolean).length / WPM));
---
<MainLayout title={`Blog Page ${pager.currentPage}`} description="Blog archive pagination">
  <section class="page-hero bs-starfield" aria-label="Page intro">
    <div class="page-hero__inner">
      <div class="bs-label page-hero__kicker">
        <svg class="bs-twinkle" viewBox="0 0 100 100" width="18" height="18" aria-hidden="true">
          <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gold-400)" />
        </svg>
        Notebook since 2001
      </div>
      <div class="page-hero__row">
        <h1>Blog, page {pager.currentPage}</h1>
        <span class="page-hero__count">page {pager.currentPage} of {pager.totalPages}</span>
      </div>
      <p class="page-hero__desc">Continuing through the writing archive.</p>
    </div>
  </section>
  <section class="section" style="display:flex;flex-direction:column;gap:var(--space-5)">
    {pager.items.map((post) => <PostListItem variant="full" href={post.permalink} title={post.title} date={post.date} excerpt={post.excerpt} categories={post.categories} image={post.header?.teaser} readMinutes={readMinutes(post.rawContent)} />)}
  </section>
  <Pagination currentPage={pager.currentPage} totalPages={pager.totalPages} basePath="/blog" />
</MainLayout>
