---
import MainLayout from '../../layouts/MainLayout.astro';
import Pagination from '../../components/Pagination.astro';
import PostListItem from '../../components/PostListItem.astro';
import { getPosts, paginate } from '../../lib/content';

const allPosts = getPosts();
const pager = paginate(allPosts, 1, 8);

const WPM = 220;
const readMinutes = (raw?: string) => Math.max(1, Math.round((raw ?? '').split(/\s+/).filter(Boolean).length / WPM));
---
<MainLayout title="Blog" description="A list of blog posts made by Steven Smethurst.">

  <section class="page-hero bs-starfield" aria-label="Page intro">
    <div class="page-hero__inner">
      <div class="bs-label page-hero__kicker">
        <svg class="bs-twinkle" viewBox="0 0 100 100" width="18" height="18" aria-hidden="true">
          <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gold-400)" />
        </svg>
        Notebook since 2001
      </div>
      <div class="page-hero__row">
        <h1>Blog</h1>
        <span class="page-hero__count">{allPosts.length.toLocaleString()} posts</span>
      </div>
      <p class="page-hero__desc">Writing stretching from early web-era notes through current project retrospectives.</p>
    </div>
  </section>

  <div class="blog-shell">

    <div class="blog-list">
      {pager.items.map((post) => (
        <PostListItem
          variant="full"
          href={post.permalink}
          title={post.title}
          date={post.date}
          excerpt={post.excerpt}
          categories={post.categories}
          tags={post.tags}
          image={post.header?.teaser}
          readMinutes={readMinutes(post.rawContent)}
        />
      ))}
    </div>

    <Pagination currentPage={pager.currentPage} totalPages={pager.totalPages} basePath="/blog" />
  </div>

</MainLayout>

<style>
  /* Container width matches other index pages */
  .blog-shell {
    max-width: var(--container);
    margin: 0 auto;
  }
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
</style>
