---
import MainLayout from '../layouts/MainLayout.astro';
import PostListItem from '../components/PostListItem.astro';
import { getPages, getPosts, getProjects, getFlockingAiEntries } from '../lib/content';
const pages = getPages().filter((page) => !page.redirectTo && page.permalink !== '/404.html');
const posts = getPosts();
const projects = getProjects();
const flocking = getFlockingAiEntries();
---
<MainLayout title="Sitemap" description="A list of all the posts and pages found on the site.">
  <section class="page-hero bs-starfield" aria-label="Page intro">
    <div class="page-hero__inner">
      <div class="bs-label page-hero__kicker">
        <svg class="bs-twinkle" viewBox="0 0 100 100" width="18" height="18" aria-hidden="true">
          <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gold-400)" />
        </svg>
        Navigation
      </div>
      <h1>Sitemap</h1>
      <p class="page-hero__desc">A complete human-readable listing of the main site's routes and collections. XML sitemap remains available for crawlers.</p>
    </div>
  </section>
  <section class="section archive-list">
    <div class="archive-panel">
      <h2>Pages</h2>
      <div class="archive-list">
        {pages.map((page) => <PostListItem variant="compact" href={page.permalink} title={page.title} date={page.date} excerpt={page.excerpt} />)}
      </div>
    </div>
    <div class="archive-panel">
      <h2>Projects</h2>
      <div class="archive-list">
        {projects.map((page) => <PostListItem variant="compact" href={page.permalink} title={page.title} date={page.date} excerpt={page.excerpt} />)}
      </div>
    </div>
    <div class="archive-panel">
      <h2>Flocking AI</h2>
      <div class="archive-list">
        {flocking.map((page) => <PostListItem variant="compact" href={page.permalink} title={page.title} date={page.date} excerpt={page.excerpt} />)}
      </div>
    </div>
    <div class="archive-panel">
      <h2>Posts</h2>
      <div class="archive-list">
        {posts.slice(0, 200).map((page) => <PostListItem variant="compact" href={page.permalink} title={page.title} date={page.date} excerpt={page.excerpt} />)}
      </div>
      <p>Showing the 200 most recent posts here; the full archive remains available through year, tag, and category routes.</p>
    </div>
  </section>
</MainLayout>
