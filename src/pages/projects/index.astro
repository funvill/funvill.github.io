---
import MainLayout from '../../layouts/MainLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import { getProjects, collectCategories, slugify } from '../../lib/content';

const allProjects = getProjects();
const allCategories = collectCategories(allProjects);

// Server-side filter by ?category= param
const selectedCategory = Astro.url.searchParams.get('category') ?? '';
const projects = selectedCategory
  ? allProjects.filter((p) => p.categories.some((c) => slugify(c) === selectedCategory))
  : allProjects;
---
<MainLayout title="Projects" description="A list of projects Steven Smethurst has worked on.">

  <section class="page-hero bs-starfield" aria-label="Page intro">
    <div class="page-hero__inner">
      <div class="bs-label page-hero__kicker">
        <svg class="bs-twinkle" viewBox="0 0 100 100" width="18" height="18" aria-hidden="true">
          <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gold-400)" />
        </svg>
        The whole workshop
      </div>
      <div class="page-hero__row">
        <h1>Projects</h1>
        <span class="page-hero__count">{allProjects.length} projects</span>
      </div>
      <p class="page-hero__desc">Everything I have built and bothered to write up. Filter by what it is made of.</p>
    </div>
  </section>

  <!-- Filter chips: DS Tag-as-button with active = solid blue. "★ all" label per DS. -->
  <div class="bs-filters" role="navigation" aria-label="Filter by category">
    <a href="/projects" class={`bs-tag${!selectedCategory ? ' active' : ''}`}>
      {!selectedCategory ? '★ all' : 'all'}
    </a>
    {allCategories.map((cat) => (
      <a
        href={`/projects?category=${cat.slug}`}
        class={`bs-tag${selectedCategory === cat.slug ? ' active' : ''}`}
      >
        {cat.name.toLowerCase()}
      </a>
    ))}
  </div>

  <!-- Project grid -->
  {projects.length > 0
    ? (
      <div class="grid">
        {projects.map((project) => (
          <EntryCard
            href={project.permalink}
            title={project.title}
            excerpt={project.excerpt}
            image={project.header.teaser}
            category={project.categories[0]}
            date={project.date ? String(project.date.getUTCFullYear()) : undefined}
            tags={project.tags}
          />
        ))}
      </div>
    )
    : (
      <div class="projects-empty">
        <svg viewBox="0 0 100 100" width="48" height="48" aria-hidden="true">
          <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gray-300)" />
        </svg>
        <p>No projects found for that category.</p>
        <a href="/projects" class="button alt">Clear filter</a>
      </div>
    )
  }

</MainLayout>

<style>
  .projects-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-9) var(--space-4);
    text-align: center;
    color: var(--text-muted);
  }
</style>
