---
import MainLayout from '../layouts/MainLayout.astro';
import { getPageByPermalink, getProjects } from '../lib/content';

const page = getPageByPermalink('/cv');
const allProjects = getProjects();
const selectedProjects = [...allProjects]
  .sort((a, b) => (b.date?.getTime() ?? 0) - (a.date?.getTime() ?? 0))
  .slice(0, 5);

const toneFor = (cat?: string) => {
  const slug = (cat ?? '').toLowerCase().replace(/\s+/g, '-');
  return ({ electronics: 'blue', art: 'magenta', software: 'cyan', 'physical-computing': 'gold' } as Record<string, string>)[slug] || 'blue';
};
---
<MainLayout title={page?.title ?? 'CV'} description={page?.description}>

  <!-- Standard page hero (matches every other page) -->
  <section class="page-hero bs-starfield" aria-label="Page intro">
    <div class="page-hero__inner">
      <div class="bs-label page-hero__kicker">
        <svg class="bs-twinkle" viewBox="0 0 100 100" width="18" height="18" aria-hidden="true">
          <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gold-400)" />
        </svg>
        Curriculum Vitae
      </div>
      <h1>Steven Smethurst</h1>
      <p class="page-hero__desc">
        CTO at Chipkin Automation Systems by day; Artist, Maker and Hacker by night. Building things on the internet since 2001.
      </p>
    </div>
  </section>

  <!-- Selected projects -->
  <section class="section">
    <div class="section-header">
      <div>
        <div class="bs-label">
          <svg viewBox="0 0 100 100" width="12" height="12" aria-hidden="true">
            <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gold-400)" />
          </svg>
          Things I built
        </div>
        <h2>Selected projects</h2>
      </div>
      <a href="/projects" class="section-link">See all {allProjects.length} →</a>
    </div>
    <div class="cv-proj-list">
      {selectedProjects.map((p) => (
        <a class="cv-proj" href={p.permalink}>
          <span class="cv-proj__year">{p.date?.getUTCFullYear() ?? ''}</span>
          <span class="cv-proj__title">{p.title}</span>
          {p.categories[0] && (
            <span class={`bs-badge bs-badge--${toneFor(p.categories[0])}`}>{p.categories[0]}</span>
          )}
        </a>
      ))}
    </div>
  </section>

  <!-- Timeline (markdown body) -->
  {page && (
    <section class="section">
      <div class="section-header">
        <div>
          <div class="bs-label">
            <svg viewBox="0 0 100 100" width="12" height="12" aria-hidden="true">
              <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gold-400)" />
            </svg>
            Course of life
          </div>
          <h2>Timeline</h2>
        </div>
      </div>
      <div class="article-body cv-body" set:html={page.html}></div>
    </section>
  )}

</MainLayout>

<style>
  /* Selected projects row cards */
  .cv-proj-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .cv-proj {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    background: var(--gray-0);
    border: var(--bw-1) solid var(--ink);
    border-radius: var(--radius-md);
    box-shadow: var(--cel-1);
    padding: 12px var(--space-5);
    transition: transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out);
  }
  .cv-proj:hover { transform: translate(-2px,-2px); box-shadow: var(--cel-2); }
  .cv-proj__year {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--blue-600);
    flex: none;
    width: 44px;
  }
  .cv-proj__title {
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    font-size: 17px;
    color: var(--text-strong);
    flex: 1;
  }

  /* Timeline body */
  .cv-body { max-width: 760px; font-size: 16px; line-height: var(--lh-relaxed); color: var(--text-body); }
  .cv-body h2 {
    font-size: var(--fs-xl);
    margin-top: var(--space-7);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .cv-body h2::before {
    content: '';
    display: inline-block;
    width: 14px;
    height: 14px;
    background-color: var(--blue-500);
    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
    flex-shrink: 0;
  }
  .cv-body h3 {
    color: var(--blue-600);
    font-size: var(--fs-lg);
    margin-top: var(--space-5);
  }
  .cv-body ul { padding-left: var(--space-5); }
  .cv-body li { margin-bottom: var(--space-1); }
  .cv-body a { color: var(--blue-600); }
  .cv-body a:hover { color: var(--blue-700); }
</style>
