---
import MainLayout from '../layouts/MainLayout.astro';
import EntryCard from '../components/EntryCard.astro';
import PostListItem from '../components/PostListItem.astro';
import { getPageByPermalink, getProjects, getPosts } from '../lib/content';

const page = getPageByPermalink('/about');
const allProjects = getProjects();
const featured = allProjects.slice(0, 3);
const allPosts = getPosts();
const recentPosts = allPosts.slice(0, 3);

const WPM = 220;
const readMinutes = (raw?: string) => Math.max(1, Math.round((raw ?? '').split(/\s+/).filter(Boolean).length / WPM));
---
<MainLayout title={page?.title ?? 'About'} description={page?.description}>

  <!-- Starfield hero (mirrors DS AboutScreen.jsx) -->
  <section class="about-hero bs-starfield" aria-label="Introduction">
    <div class="about-hero__inner">
      <!-- Profile photo: 168 squircle (radius-md) with drop-shadow wrapper per DS -->
      <div class="about-hero__avatar-wrap">
        <span class="about-hero__avatar">
          <img
            src="https://github.com/funvill.png"
            alt="Steven Smethurst"
            width="168"
            height="168"
            loading="eager"
          />
        </span>
      </div>

      <div class="about-hero__blurb">
        <div class="about-hero__kicker">
          <svg class="bs-twinkle" viewBox="0 0 100 100" width="18" height="18" aria-hidden="true">
            <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gold-400)" />
          </svg>
          <span class="bs-label" style="color: var(--cyan-300)">Artist &middot; Maker &middot; Hacker &middot; Vancouver, BC</span>
        </div>

        <h1>About Steven Smethurst</h1>

        <div class="about-hero__prose">
          <p>
            Hi 👋🏼 I'm <a href="/about" class="bs-pill bs-pill--blue">Steven Smethurst</a> and I live two lives. During the day I am a CTO at <a href="http://store.chipkin.com/" class="bs-pill bs-pill--cyan">Chipkin Automation Systems</a> making devices talk to each other, and at night I am a 👨‍🎨 <a href="/cv/" class="bs-pill bs-pill--magenta">Artist</a>, Maker, Hacker, and all around great guy.
          </p>

          <p>
            If I'm not <span title="Making computers talk to each other">beep booping</span> at my day job, I might be 🌳 <a href="/projects/2020-vancouver-parks/" class="bs-pill bs-pill--blue">visiting every park in Vancouver</a>, or making a deck of cards with 📸🐦 <a href="/projects/2021-bird-playing-cards/" class="bs-pill bs-pill--cyan">photos of birds</a>, or working on one of my many side <a href="/projects/" class="bs-pill bs-pill--blue">Projects</a>. <a href="/now" class="bs-pill bs-pill--magenta">See what I'm currently working on →</a>
          </p>

          <p>
            My interests bounce around to whatever catches my attention. <a href="/projects/2022-monthly-habit-tracker/" class="bs-pill bs-pill--blue">PCB Design</a>, Paper craft, 🪟 <a href="/projects/2018-stained-glass-window/" class="bs-pill bs-pill--cyan">Stained Glass</a>, 🗺️ Maps, 🎲 <a href="/projects/2023-skull-game-pcb/" class="bs-pill bs-pill--blue">Boardgames</a>, <a href="/projects/2019-illuminated-stained-glass-sixteen-segment-display/" class="bs-pill bs-pill--magenta">Segment Displays</a>, <a href="/projects/2017-laser-kaleidoscope/" class="bs-pill bs-pill--blue">Lasers and kaleidoscopes</a>, and anything that glows.
          </p>

          <p>
            I've been writing in my <a href="/blog/" class="bs-pill bs-pill--cyan">blog</a> since 2001. I use <a href="https://www.instagram.com/funvill/" class="bs-pill bs-pill--magenta">Instagram</a> to post in-progress updates of my current projects. Feel free to connect!
          </p>
        </div>

        <div class="about-hero__actions">
          <a class="bs-btn bs-btn--primary bs-btn--lg" href="/projects">
            Browse projects
            <svg viewBox="0 0 100 100" width="16" height="16" aria-hidden="true">
              <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="#fff" />
            </svg>
          </a>
          <a class="bs-btn bs-btn--outline bs-btn--lg" href="/blog">Read the blog</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured projects -->
  <section class="section">
    <div class="section-header">
      <div>
        <div class="bs-label">
          <svg viewBox="0 0 100 100" width="12" height="12" aria-hidden="true">
            <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gold-400)" />
          </svg>
          Recent
        </div>
        <h2>Featured projects</h2>
      </div>
      <a href="/projects" class="section-link">See all {allProjects.length} →</a>
    </div>
    <div class="grid">
      {featured.map((project) => (
        <EntryCard
          href={project.permalink}
          title={project.title}
          excerpt={project.excerpt}
          image={project.header.teaser}
          category={project.categories[0]}
          date={project.date ? String(project.date.getUTCFullYear()) : undefined}
          tags={project.tags}
        />
      ))}
    </div>
  </section>

  <!-- Recent posts -->
  <section class="section">
    <div class="section-header">
      <div>
        <div class="bs-label">
          <svg viewBox="0 0 100 100" width="12" height="12" aria-hidden="true">
            <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gold-400)" />
          </svg>
          Recent
        </div>
        <h2>From the blog</h2>
      </div>
      <a href="/blog" class="section-link">All posts →</a>
    </div>
    <div class="post-list">
      {recentPosts.map((post) => (
        <PostListItem
          variant="full"
          href={post.permalink}
          title={post.title}
          date={post.date}
          excerpt={post.excerpt}
          categories={post.categories}
          image={post.header?.teaser}
          readMinutes={readMinutes(post.rawContent)}
        />
      ))}
    </div>
  </section>

</MainLayout>

<style>
  /* ──────────────── Hero (mirrors DS AboutScreen.jsx) ──────────────── */
  .about-hero {
    /* Full-bleed: break out of .shell so starfield extends edge-to-edge */
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    margin-top: calc(var(--space-6) * -1);
    margin-bottom: var(--space-7);
    border-bottom: var(--bw-1) solid var(--ink);
    position: relative;
    overflow: hidden;
  }
  .about-hero__inner {
    width: min(calc(100% - 2 * var(--space-5)), var(--container));
    margin: 0 auto;
    padding: var(--space-9) var(--space-5);
    display: flex;
    gap: var(--space-7);
    align-items: flex-start;
    flex-wrap: wrap;
  }

  /* Avatar — 168px squircle (radius-md) with ink drop-shadow on wrapper */
  .about-hero__avatar-wrap {
    flex: none;
    filter: drop-shadow(5px 5px 0 var(--ink));
  }
  .about-hero__avatar {
    display: inline-flex;
    width: 168px;
    height: 168px;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--blue-500);
    border: var(--bw-1) solid var(--ink);
  }
  .about-hero__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Blurb column */
  .about-hero__blurb { flex: 1; min-width: 320px; }
  .about-hero__kicker {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .about-hero h1 {
    color: #fff;
    font-size: clamp(30px, 4vw, 46px);
    line-height: 1.08;
    margin: 0 0 18px;
    letter-spacing: var(--ls-tight);
  }
  .about-hero__prose {
    color: rgba(255,255,255,0.85);
    font-size: 18px;
    line-height: 1.7;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .about-hero__prose p { margin: 0; }
  .about-hero__actions {
    display: flex;
    gap: 14px;
    margin-top: 24px;
    flex-wrap: wrap;
  }

  /* ──────────────── Inline hero pill ──────────────── */
  /* Borderless, compact — sized to fit comfortably inside the 1.7 line-height
     so consecutive rows of pills never touch each other. */
  .bs-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    vertical-align: baseline;
    padding: 1px 9px 2px;
    margin: 0 1px;
    border: none;
    border-radius: var(--radius-pill);
    color: #fff;
    text-decoration: none;
    white-space: nowrap;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85em;
    line-height: 1.25;
    box-shadow: 1px 1px 0 rgba(3,8,28,0.45);
    transition: filter var(--dur-fast), transform var(--dur-fast);
  }
  /* Leading star, 10px white */
  .bs-pill::before {
    content: '';
    width: 10px;
    height: 10px;
    flex-shrink: 0;
    background: #fff;
    -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><polygon points='50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38'/></svg>") center/contain no-repeat;
            mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><polygon points='50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38'/></svg>") center/contain no-repeat;
  }
  .bs-pill--blue    { background: var(--blue-500); }
  .bs-pill--cyan    { background: var(--cyan-600); }
  .bs-pill--magenta { background: var(--magenta-400); }
  .bs-pill:hover { filter: brightness(1.12); transform: translateY(-1px); }

  /* ──────────────── Post list spacing ──────────────── */
  .post-list { display: flex; flex-direction: column; gap: var(--space-5); }

  /* ──────────────── Mobile ──────────────── */
  @media (max-width: 720px) {
    .about-hero__inner { padding: var(--space-7) var(--space-5); gap: var(--space-5); }
    .about-hero__avatar { width: 140px; height: 140px; }
  }
</style>
