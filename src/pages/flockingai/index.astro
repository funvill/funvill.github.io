---
import MainLayout from '../../layouts/MainLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import { getFlockingAiEntries } from '../../lib/content';

const entries = getFlockingAiEntries();
---
<MainLayout title="Flocking AI" description="AI/ML created birds for the Flocking AI project.">
  <section class="page-hero bs-starfield" aria-label="Page intro">
    <div class="page-hero__inner">
      <div class="bs-label page-hero__kicker">
        <svg class="bs-twinkle" viewBox="0 0 100 100" width="18" height="18" aria-hidden="true">
          <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gold-400)" />
        </svg>
        Field guide of imaginary birds
      </div>
      <h1>Flocking AI</h1>
      <p class="page-hero__desc">A long-running collection of generated birds, prompt experiments, and a custom presentation distinct from the rest of the archive.</p>
      <div class="page-hero__actions">
        <a class="bs-btn bs-btn--primary" href="/projects/2022-flocking-ai/">Project overview</a>
        <a class="bs-btn bs-btn--outline" href="https://www.instagram.com/flockingai/" target="_blank" rel="noopener noreferrer">Instagram</a>
      </div>
    </div>
  </section>
  <section class="section grid">
    {entries.map((entry) => <EntryCard href={entry.permalink} title={entry.title} excerpt={entry.excerpt} image={entry.gallery?.[0] ?? entry.header.teaser} meta={entry.species ?? 'Imaginary bird'} />)}
  </section>
</MainLayout>
