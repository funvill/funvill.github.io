---
import MainLayout from '../../layouts/MainLayout.astro';
import PillLink from '../../components/PillLink.astro';
import { collectCategories, getPosts } from '../../lib/content';
const categories = collectCategories(getPosts());
---
<MainLayout title="Posts by Category" description="Browse posts by category.">
  <section class="page-hero bs-starfield" aria-label="Page intro">
    <div class="page-hero__inner">
      <div class="bs-label page-hero__kicker">
        <svg class="bs-twinkle" viewBox="0 0 100 100" width="18" height="18" aria-hidden="true">
          <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gold-400)" />
        </svg>
        Archive filters
      </div>
      <div class="page-hero__row">
        <h1>Posts by category</h1>
        <span class="page-hero__count">{categories.length} categories</span>
      </div>
      <p class="page-hero__desc">Category archive preserved from the Jekyll site, with a redesigned overview.</p>
    </div>
  </section>
  <section class="section archive-panel">
    <div class="taxonomy">
      {categories.map((category) => <PillLink href={`/categories/${category.slug}/`} label={category.name} count={category.count} />)}
    </div>
  </section>
</MainLayout>
