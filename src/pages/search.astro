---
import MainLayout from '../layouts/MainLayout.astro';
const query = Astro.url.searchParams.get('q') ?? '';
---
<MainLayout title="Search" description="Search blog posts and projects.">

  <section class="page-hero bs-starfield" aria-label="Search">
    <div class="page-hero__inner">
      <div class="bs-label page-hero__kicker">
        <svg class="bs-twinkle" viewBox="0 0 100 100" width="18" height="18" aria-hidden="true">
          <polygon points="50,2 61,38 98,38 68,60 79,96 50,73 21,96 32,60 2,38 39,38" fill="var(--gold-400)" />
        </svg>
        Full-text search
      </div>
      <div class="page-hero__row">
        <h1>Search</h1>
      </div>
      <p class="page-hero__desc">Search across all blog posts and projects.</p>
    </div>
  </section>

  <div class="search-shell">
    <div id="search-ui"></div>
    <noscript>
      <p>JavaScript is required for search.</p>
    </noscript>
  </div>

</MainLayout>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script define:vars={{ query }}>
  window.addEventListener('DOMContentLoaded', () => {
    const ui = new PagefindUI({
      element: '#search-ui',
      showSubResults: true,
      showImages: true,
    });
    if (query) {
      ui.triggerSearch(query);
    }
  });
</script>

<style>
  .search-shell {
    max-width: var(--container);
    margin: 0 auto;
    padding: var(--space-6) 0 var(--space-8);
  }
</style>
